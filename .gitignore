# Obsidian 配置目录
.obsidian/

# 系统文件
.DS_Store
Thumbs.db

# PDF 原文（本地存放，不纳入版本控制）
literature/**/*.pdf
research/**/*.pdf

# 临时文件
*.tmp
*.tmp.*
*~

# LaTeX 编译产物
talks/**/build/

# 幻灯片编译输出 PDF（位于讲稿根目录，如 template.pdf）
# figures/ 下的矢量图在更深一层，不受影响；logo.pdf 显式保留
talks/*/*.pdf
!talks/*/logo.pdf
*.aux
*.log
*.out
*.toc
*.lof
*.lot
*.bbl
*.blg
*.bcf
*.run.xml
*.fls
*.fdb_latexmk
*.synctex.gz
*.nav
*.snm
*.vrb
*.idx
*.ind
*.ilg
*.glo
*.gls
*.glg
*.acn
*.acr
*.alg
*.xdy
.winuser/
tmp/

# Local MiKTeX cache created when compiling under sandboxed user dirs
.miktex/
talks/**/.miktex/
talks/**/.miktex-userconfig/
talks/**/.miktex-userdata/
