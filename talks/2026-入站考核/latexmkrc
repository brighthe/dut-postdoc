# latexmkrc —— 编译配置（XeLaTeX，产物输出到 build/）
# 用法：latexmk template.tex
# TeXstudio：选项 → 构建 → 默认编译器选 latexmk

# 使用 XeLaTeX（支持中文）
$pdf_mode = 5;

# XeLaTeX 命令：开启 synctex（正反向搜索），出错不停顿
$xelatex = 'xelatex -synctex=1 -interaction=nonstopmode -file-line-error %O %S';

# 所有编译产物（含最终 PDF）输出到 build/ 子目录
$out_dir = 'build';

# 自动判断编译遍数（TOC、引用等收敛），最多 5 遍
$max_repeat = 5;
